# Supabase Configuration
SUPABASE_URL=your-project-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_HOST=db.your-project.supabase.co
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your-database-password
SUPABASE_PORT=5432

# Stockfish Engine Configuration
STOCKFISH_SKILL_LEVEL=20
STOCKFISH_THREADS=4
STOCKFISH_HASH=512
STOCKFISH_MULTI_PV=1
STOCKFISH_MOVE_TIME_MS=1000

# Chess.com Configuration
CHESS_COM_USERNAME=your-username

# Next.js Environment Variables (for web app)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_CHESS_COM_USERNAME=your-username
